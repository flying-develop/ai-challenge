# ── Провайдер по умолчанию ──────────────────────────────────────────────────
# Какой провайдер использовать, если не задан --provider:
#   qwen | openai | claude
# Если не задан — берётся первый провайдер с доступным ключом.
# LLM_PROVIDER=qwen


# ── Qwen (Alibaba Cloud DashScope) ──────────────────────────────────────────
QWEN_API_KEY=your-qwen-api-key-here
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus
QWEN_TIMEOUT_SECONDS=30
# QWEN_SYSTEM_PROMPT=   # опционально: системные инструкции для ассистента


# ── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=      # опционально: Azure, Together.ai и другие совместимые API
# OPENAI_MODEL=gpt-4o-mini


# ── Claude / Anthropic ───────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001


# ── MCP (Model Context Protocol) ─────────────────────────────────────────────
# Путь к склонированному и собранному markdownify-mcp:
#   git clone https://github.com/zcaceres/markdownify-mcp.git
#   cd markdownify-mcp && pnpm install && pnpm run build
MARKDOWNIFY_MCP_PATH=/home/user/markdownify-mcp


# ── Новостной пайплайн (news_server.py) ──────────────────────────────────────

# RSS-фиды через запятую (по умолчанию — общий фид Lenta.ru)
# Доступные рубрики: /rss/news/russia, /rss/news/world, /rss/news/economics,
#                    /rss/news/science, /rss/news/sport, /rss/news/culture
NEWS_RSS_FEEDS=https://lenta.ru/rss

# Максимум статей на одну категорию для суммаризации (0 = без ограничений)
NEWS_MAX_ARTICLES_PER_CATEGORY=10

# Интервал запуска пайплайна в минутах (для планировщика news_scheduler.py)
NEWS_POLL_INTERVAL_MINUTES=60

# Рабочие часы (МСК): пайплайн запускается только в это окно
NEWS_WORK_HOURS_START=09
NEWS_WORK_HOURS_END=17

# Список категорий для отслеживания через запятую (пустое = все)
# Возможные значения: russia, world, economics, science, sport, culture
NEWS_CATEGORIES=russia,world,economics,science,sport,culture

# Путь к SQLite-базе для хранения суммаризаций (по умолчанию data/news_pipeline.db)
# NEWS_DB_PATH=data/news_pipeline.db


# ── Telegram (для отправки новостных сводок) ─────────────────────────────────

# Токен Telegram-бота (получить у @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Ваш личный chat_id (числовой) — бот будет присылать сводки прямо вам.
#
# Как узнать свой chat_id:
#   1. Создайте бота у @BotFather → получите токен выше
#   2. Напишите боту /start в Telegram (личные сообщения)
#   3. Запустите: python -m mcp_server.news_api
#      Скрипт выведет ваш chat_id автоматически
#
# Для канала можно указать @username: TELEGRAM_CHAT_ID=@mychannel
# Для личных сообщений — только числовой id: TELEGRAM_CHAT_ID=123456789
TELEGRAM_CHAT_ID=123456789


# ── Исследовательский агент (search_server + scraper_server + orchestrator) ──

# Режим поиска: yandex_cloud (реальный поиск) или mock (заглушка без ключей)
# По умолчанию mock — работает без регистрации в Yandex Cloud
SEARCH_MODE=mock

# Yandex Cloud Search API (нужен только при SEARCH_MODE=yandex_cloud)
# Регистрация: https://yandex.cloud/
# folder_id: https://yandex.cloud/en-ru/docs/resource-manager/operations/folder/get-id
# oauth_token: https://yandex.cloud/en-ru/docs/iam/concepts/authorization/oauth-token
# YANDEX_CLOUD_FOLDER_ID=your_folder_id
# YANDEX_CLOUD_OAUTH_TOKEN=your_oauth_token

# Максимум результатов поиска на запрос (жёстко ограничено 10 на уровне сервера)
SEARCH_MAX_RESULTS=10

# Таймаут scraper_server на загрузку одной страницы (секунды)
SCRAPER_TIMEOUT=10

# Обрезка контента страницы (символы)
SCRAPER_MAX_CONTENT_LENGTH=3000

# Максимум ссылок на один поисковый раунд (инвариант: ≤ 10)
RESEARCH_MAX_LINKS_PER_ROUND=10

# Максимум поисковых запросов на первый раунд (рекомендуется 2-4)
RESEARCH_MAX_SEARCH_QUERIES=4

# Путь к SQLite-базе журнала (по умолчанию ~/.llm-agent/research_journal.db)
# JOURNAL_DB_PATH=data/research_journal.db
